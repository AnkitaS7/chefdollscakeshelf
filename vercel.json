{
  "version": 2,
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "vite build && esbuild server/vercel-handler.ts --platform=node --packages=external --bundle --format=esm --outfile=api/index.js",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
